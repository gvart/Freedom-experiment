{
  "name": "patchwork",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "bun run --filter @patchwork/api db:migrate",
    "db:seed": "bun run --filter @patchwork/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.8"
  }
}
