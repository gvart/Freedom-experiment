# Patchwork Environment Configuration
# Copy this to .env and adjust as needed.

# Server port (default: 3000 in Docker, 3001 in dev)
PORT=3000

# SQLite database path (default: /data/patchwork.db in Docker)
DATABASE_URL=/data/patchwork.db

# Public base URL (used in RSS feeds, links)
BASE_URL=http://localhost:3000

# CORS allowed origins (comma-separated, or "*" for all)
CORS_ORIGINS=*

# Session cookie max age in seconds (default: 30 days)
# SESSION_MAX_AGE=2592000

# Path to built web assets (set automatically in Docker)
# STATIC_DIR=packages/web/dist
